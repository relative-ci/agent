{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "node",
    "allowJs": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": false,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["node"],
    /* target config for node 22 */
    "target": "ES2023",
    "lib": ["ES2023"],
    "paths": {
      "@relative-ci/core/*": ["./packages/core/src/*"],
      "@relative-ci/core": ["./packages/core/src"],
    },
  },
  "ts-node": {
    "compilerOptions": {
      "module": "CommonJS",
    },
  },
}
