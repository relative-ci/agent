{
  "name": "@relative-ci/core",
  "version": "5.3.1",
  "description": "Core library for RelativeCI agent - send bundle stats and CI build information to RelativeCI",
  "keywords": [
    "relative-ci",
    "webpack",
    "vitejs",
    "rspack",
    "rollup",
    "bundle-size",
    "bundle-analyzer",
    "bundle-stats",
    "stats",
    "bundle",
    "size",
    "assets",
    "chunks",
    "modules"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/relative-ci/agent",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/relative-ci/agent/issues"
  },
  "homepage": "https://relative-ci.com/documentation/setup",
  "license": "MIT",
  "author": {
    "name": "Viorel Cojocaru",
    "email": "vio@relative-ci.com",
    "url": "https://relative-ci.com"
  },
  "engines": {
    "node": ">= 18.0.0"
  },
  "main": "./lib/cjs/index.js",
  "module": "./lib/esm/index.js",
  "types": "./lib/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/types/index.d.ts",
      "require": "./lib/cjs/index.js",
      "import": "./lib/esm/index.js"
    },
    "./env": {
      "types": "./lib/types/env/index.d.ts",
      "require": "./lib/cjs/env.js",
      "import": "./lib/esm/env.js"
    },
    "./artifacts": {
      "types": "./lib/types/artifacts/index.d.ts",
      "require": "./lib/cjs/artifacts.js",
      "import": "./lib/esm/artifacts.js"
    },
    "./ingest": {
      "types": "./lib/types/ingest/index.d.ts",
      "require": "./lib/cjs/ingest.js",
      "import": "./lib/esm/ingest.js"
    },
    "./utils": {
      "types": "./lib/types/utils/index.d.ts",
      "require": "./lib/cjs/utils.js",
      "import": "./lib/esm/utils.js"
    },
    "./locales/en": {
      "types": "./lib/types/locales/en.d.ts",
      "require": "./lib/cjs/locales/en.js",
      "import": "./lib/esm/locales/en.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "npm run clean && tsc && rollup -c && npm run build-type",
    "build-type": "echo '{\"type\":\"commonjs\"}' > lib/cjs/package.json && echo '{\"type\":\"module\"}' > lib/esm/package.json",
    "clean": "rimraf ./lib",
    "lint": "eslint .",
    "test": "vitest src --passWithNoTests --run"
  },
  "devDependencies": {
    "@octokit/webhooks-types": "7.6.1",
    "@rollup/plugin-commonjs": "29.0.2",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-replace": "6.0.3",
    "@rollup/plugin-typescript": "12.3.0",
    "@tsconfig/node18": "18.2.6",
    "@types/debug": "4.1.13",
    "@types/env-ci": "3.1.4",
    "@types/fs-extra": "11.0.4",
    "@types/lodash": "4.17.24",
    "env-ci": "11.2.0",
    "rimraf": "6.1.3",
    "rollup": "4.60.2",
    "rollup-plugin-node-externals": "9.0.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.0",
    "vitest": "4.1.5"
  },
  "dependencies": {
    "@actions/github": "8.0.0",
    "@bundle-stats/plugin-webpack-filter": "4.21.10",
    "@bundle-stats/plugin-webpack-validate": "4.21.10",
    "debug": "4.4.3",
    "dotenv": "17.3.1",
    "fs-extra": "11.3.4",
    "lodash": "4.18.1"
  }
}
